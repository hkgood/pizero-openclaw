# ── Provider selection ─────────────────────────────────────────────────────────
# STT: funasr (default, cloud) or openai
STT_PROVIDER="funasr"
# TTS: bailian (default) or openai
TTS_PROVIDER="bailian"

# ── Bailian / DashScope (FunASR ASR + Qwen TTS) ──────────────────────────────
# Get your API key from: https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY="your-dashscope-api-key"
DASHSCOPE_API_BASE="https://dashscope.aliyuncs.com"

# Bailian TTS settings
BAILIAN_TTS_MODEL="qwen3-tts-flash"
# 可选音色（中文）：
#   Cherry=芊悦(女)  Serena=苏瑶(女)  Chelsie=千雪(女)  Momo=茉兔(女)
#   Vivian=十三(女)  Moon=月白(女)    Maia=四月(女)     Bella=萌宝(女)
#   Jennifer=詹妮弗(女) Ryan=甜茶(男)  Nini=邻家妹妹(女)  Seren=小婉(女)
#   Ethan=晨煦(男)   Kai=凯(男)      Neil=阿闻(男)     Vincent=田叔(男)
#   Elias=墨讲师(男) Arthur=徐大爷(男) Nofish=不吃鱼(男)
#   Dylan=北京-晓东(男方言)  Jada=上海-阿珍(女方言)  Li=南京-老李(男方言)
BAILIAN_TTS_VOICE="Cherry"
BAILIAN_TTS_SPEED="1.0"
BAILIAN_TTS_GAIN_DB="9"

# ── OpenAI (fallback) ─────────────────────────────────────────────────────────
# OPENAI_API_KEY="sk-your-openai-api-key"
# OPENAI_TRANSCRIBE_MODEL="whisper-1"
# OPENAI_TTS_MODEL="tts-1"
# OPENAI_TTS_VOICE="coral"
# OPENAI_TTS_SPEED="1.1"

# ── OpenClaw ─────────────────────────────────────────────────────────────────
# Preferred remote topology: keep the Gateway on loopback and reach it locally
# or through an SSH tunnel (for example: ssh -N -L 18789:127.0.0.1:18789 user@host).
# Then keep OPENCLAW_BASE_URL pointed at the forwarded local address.
OPENCLAW_BASE_URL="http://127.0.0.1:18789"
# Shared gateway auth: set either token or password to match the server.
# Do not commit real secrets; keep them only in the local .env on the Pi.
# Token is recommended when the server uses token auth.
OPENCLAW_TOKEN=""
# Password is recommended when the server uses auth.mode=password.
OPENCLAW_PASSWORD=""
OPENCLAW_PROTOCOL_VERSION="3"
OPENCLAW_CLIENT_ID="cli"
OPENCLAW_CLIENT_MODE="cli"
OPENCLAW_CLIENT_VERSION="1.0.0"
OPENCLAW_ROLE="operator"
OPENCLAW_SCOPES="operator.read,operator.write"
OPENCLAW_LOCALE="zh-CN"
OPENCLAW_USER_AGENT="pizero-openclaw/1.0.0"
OPENCLAW_DEVICE_FAMILY="raspberry-pi-zero-2w"
# Latest 3.31+ flow: use shared auth together with device identity.
# First connect may become pending pairing once; after approval the client will
# persist the returned deviceToken and reconnect cleanly.
OPENCLAW_USE_DEVICE_IDENTITY="true"
OPENCLAW_IDENTITY_FILE="~/.openclaw/identity/device.json"
OPENCLAW_DEVICE_TOKEN_FILE="~/.openclaw/identity/device-auth.json"
OPENCLAW_PAIRING_STATE_FILE="~/.openclaw/pizero/pairing-state.json"
OPENCLAW_SESSION_KEY="main"
OPENCLAW_ALLOW_SHARED_TOKEN_FALLBACK="true"
OPENCLAW_CONNECT_TIMEOUT_MS="10000"
OPENCLAW_REQUEST_TIMEOUT_MS="30000"
OPENCLAW_STREAM_TIMEOUT_MS="120000"
OPENCLAW_STREAM_EVENT_TIMEOUT_MS="15000"
OPENCLAW_HEALTHCHECK_TIMEOUT_MS="8000"
OPENCLAW_PING_INTERVAL_SEC="15"

# ── Audio ─────────────────────────────────────────────────────────────────────
AUDIO_DEVICE="plughw:1,0"
AUDIO_OUTPUT_DEVICE="default"
AUDIO_SAMPLE_RATE="16000"

# ── UI ─────────────────────────────────────────────────────────────────────────
LCD_BACKLIGHT="70"
UI_MAX_FPS="4"

# ── Behaviour ─────────────────────────────────────────────────────────────────
ENABLE_TTS="true"
CONVERSATION_HISTORY_LENGTH="5"
MAX_CONTEXT_TOKENS="16000"
SILENCE_RMS_THRESHOLD="200"

# ── Test Mode ────────────────────────────────────────────────────────────────
# Set to "true" to run without WhisPlay hardware (text input + mock display)
TEST_MODE="false"
