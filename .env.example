# ─── Provider selection ───────────────────────────────────────────────────────
# Set TTS_PROVIDER and STT_PROVIDER to "minimax" or "openai"
export TTS_PROVIDER="minimax"
export STT_PROVIDER="minimax"

# ─── MiniMax API (primary, recommended) ──────────────────────────────────────
# Get your API key from https://platform.minimaxi.com/
export MINIMAX_API_KEY="your-minimax-api-key"
export MINIMAX_STT_MODEL="speech-01-mini"
export MINIMAX_TTS_MODEL="speech-02-horo"
export MINIMAX_TTS_VOICE="male-qn-qingse"
export MINIMAX_TTS_SPEED="1.0"
export MINIMAX_TTS_VOLUME="1.0"
export MINIMAX_TTS_PITCH="0"
export MINIMAX_API_BASE="https://api.minimaxi.com"

# ─── OpenAI API (fallback) ────────────────────────────────────────────────────
# export OPENAI_API_KEY="sk-your-openai-api-key"
# export OPENAI_TRANSCRIBE_MODEL="gpt-4o-mini-transcribe"
# export OPENAI_TTS_MODEL="tts-1"
# export OPENAI_TTS_VOICE="alloy"
# export OPENAI_TTS_SPEED="1.1"

# ─── OpenClaw ─────────────────────────────────────────────────────────────────
export OPENCLAW_TOKEN="your-openclaw-gateway-token"
export OPENCLAW_BASE_URL="http://localhost:18789"

# ─── Audio ───────────────────────────────────────────────────────────────────
export AUDIO_DEVICE="plughw:1,0"
export AUDIO_OUTPUT_DEVICE="default"
export AUDIO_SAMPLE_RATE="16000"

# ─── UI ──────────────────────────────────────────────────────────────────────
export LCD_BACKLIGHT="70"
export UI_MAX_FPS="4"

# ─── Behaviour ───────────────────────────────────────────────────────────────
export ENABLE_TTS="true"
export CONVERSATION_HISTORY_LENGTH="5"
export SILENCE_RMS_THRESHOLD="200"
