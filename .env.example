# ── Provider selection ─────────────────────────────────────────────────────────
# STT: funasr (default, cloud) or openai
export STT_PROVIDER="funasr"
# TTS: bailian (default) or openai
export TTS_PROVIDER="bailian"

# ── Bailian / DashScope (FunASR ASR + Qwen TTS) ──────────────────────────────
# Get your API key from: https://bailian.console.aliyun.com/
export DASHSCOPE_API_KEY="your-dashscope-api-key"
export DASHSCOPE_API_BASE="https://dashscope.aliyuncs.com"

# Bailian TTS settings
export BAILIAN_TTS_MODEL="qwen3-tts-flash"
export BAILIAN_TTS_VOICE="Cherry"
export BAILIAN_TTS_SPEED="1.0"
export BAILIAN_TTS_GAIN_DB="9"

# ── OpenAI (fallback) ─────────────────────────────────────────────────────────
# export OPENAI_API_KEY="sk-your-openai-api-key"
# export OPENAI_TRANSCRIBE_MODEL="whisper-1"
# export OPENAI_TTS_MODEL="tts-1"
# export OPENAI_TTS_VOICE="coral"
# export OPENAI_TTS_SPEED="1.1"

# ── OpenClaw ─────────────────────────────────────────────────────────────────
# Auth token for the OpenClaw gateway (NOT the browser session token)
export OPENCLAW_TOKEN="your-openclaw-gateway-token"
export OPENCLAW_BASE_URL="http://localhost:18789"

# ── Audio ─────────────────────────────────────────────────────────────────────
export AUDIO_DEVICE="plughw:1,0"
export AUDIO_OUTPUT_DEVICE="default"
export AUDIO_SAMPLE_RATE="16000"

# ── UI ─────────────────────────────────────────────────────────────────────────
export LCD_BACKLIGHT="70"
export UI_MAX_FPS="4"

# ── Behaviour ─────────────────────────────────────────────────────────────────
export ENABLE_TTS="true"
export CONVERSATION_HISTORY_LENGTH="5"
export MAX_CONTEXT_TOKENS="16000"
export SILENCE_RMS_THRESHOLD="200"

# ── Test Mode ────────────────────────────────────────────────────────────────
# Set to "true" to run without WhisPlay hardware (text input + mock display)
export TEST_MODE="false"
